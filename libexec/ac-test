#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
usage: ac test [--debug|--release] [--build-only] [src]

options:
  --debug       Build with debug flags (-g -O0). (default)
  --release     Build with release flags (-O2)
  --build-only  Only build. Do not run oj tests.
  --full        Print full gdb backtrace (bt full) on runtime error.
  -h, --help    Show this help.
USAGE
}

# When `oj t` reports a failure, re-run each test case directly and, for the
# first case that crashes (non-zero / signal exit), print a gdb backtrace so
# the source location of the runtime error is visible.
show_runtime_error_detail() {
  local out="$1"
  local test_dir="$2"
  local timeout_sec="${RE_TIMEOUT_SEC:-10}"
  local runner=()
  if command -v timeout >/dev/null 2>&1; then
    runner=(timeout "$timeout_sec")
  else
    echo "[ac-test] warning: timeout(1) not found; TLE cases may hang" >&2
  fi
  if ! command -v gdb >/dev/null 2>&1; then
    echo "[ac-test] gdb not found; cannot show backtrace. install gdb." >&2
    return 0
  fi

  local in_files=()
  shopt -s nullglob
  in_files=("$test_dir"/*.in)
  shopt -u nullglob

  local found=0
  local rc=0
  for in_file in "${in_files[@]}"; do
    rc=0
    ( "${runner[@]}" "$out" < "$in_file" > /dev/null 2>/dev/null ) || rc=$?
    # rc=0  : clean exit (WA handled by oj). rc=124 : timeout (TLE). skip both.
    if [[ $rc -ne 0 && $rc -ne 124 ]]; then
      echo "" >&2
      echo "--- runtime error on: $(basename "$in_file") (exit $rc) ---" >&2
      local full="${full_bt:-0}"
      local bt_cmd="bt"
      [[ "$full" == "1" ]] && bt_cmd="bt full"
      gdb -q -batch \
        -ex "set debuginfod enabled off" \
        -ex "set pagination off" \
        -ex "set print thread-events off" \
        -ex run -ex "$bt_cmd" --args "$out" < "$in_file" >&2 \
        || echo "[ac-test] gdb exited with non-zero status" >&2
      found=1
      break
    fi
  done

  if [[ $found -eq 0 ]]; then
    echo "" >&2
    echo "[ac-test] no runtime error detected on direct runs; failure was likely WA/TLE" >&2
  fi
}

mode="debug"
build_only=0
full_bt=0
src="main.cpp"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --debug)
      mode="debug"
      shift
      ;;
    --release)
      mode="release"
      shift
      ;;
    --build-only)
      build_only=1
      shift
      ;;
    --full)
      full_bt=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      if [[ $# -gt 0 ]]; then
        src="$1"
        shift
      fi
      if [[ $# -gt 0 ]]; then
        echo "error: too many arguments" >&2
        usage
        exit 1
      fi
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage
      exit 1
      ;;
    *)
      src="$1"
      shift
      if [[ $# -gt 0 ]]; then
        echo "error: too many arguments" >&2
        usage
        exit 1
      fi
      ;;
  esac
done

if [[ ! -f "$src" ]]; then
  echo "error: source file not found: $src" >&2
  exit 1
fi

src_base="$(basename "$src")"
src_stem="${src_base%.*}"
out="./${src_stem}.out"

if [[ "$mode" == "release" ]]; then
  flags="${CXXFLAGS:-"-std=gnu++20 -O2"}"
else
  flags="${CXXFLAGS_DEBUG:-"-std=gnu++20 -g -O0 -Wall -Wextra -Wshadow -Wconversion -Wno-sign-conversion"}"
fi

# shellcheck disable=SC2086
"${CXX:-g++}" $flags "$src" -o "$out"

echo "built: $out (src: $src, mode: $mode)"

if [[ $build_only -eq 1 ]]; then
  exit 0
fi

if [[ -d test ]]; then
  oj_rc=0
  oj t -c "$out" || oj_rc=$?
  if [[ $oj_rc -ne 0 ]]; then
    echo "" >&2
    echo "[ac-test] test failed (exit $oj_rc). inspecting runtime errors..." >&2
    show_runtime_error_detail "$out" test
  fi
  exit "$oj_rc"
else
  echo "warning: ./test not found. run: ac new <contest> <task>" >&2
fi
